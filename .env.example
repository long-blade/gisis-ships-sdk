# Copy this file to .env and fill in your GISIS session cookie (NOT your password).
#
# How to get it:
#   1. Log in to https://gisis.imo.org/Public/SHIPS/Default.aspx in your browser
#      (solve the Cloudflare Turnstile + password yourself).
#   2. Open DevTools -> Application/Storage -> Cookies -> gisis.imo.org
#   3. Copy the value of the IMOWEBACC cookie below.
#
# This cookie expires; when searches start throwing AuthenticationException,
# log in again and refresh it.

GISIS_IMOWEBACC=
# Optional, helps stick to the same backend node:
GISIS_ARRAFFINITY=
GISIS_ASPNET_SESSIONID=
